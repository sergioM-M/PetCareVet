<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Consulta The Cat API"

        android:textColor="@color/vet_primary_dark"
        android:textSize="24sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/inputCatLimit"

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Número de imágenes, máximo 25"
        android:inputType="number"
        android:layout_marginTop="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSearchCats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buscar gatos"
        android:layout_marginTop="8dp" />


    <TextView
        android:id="@+id/txtCatStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/vet_text"
        android:layout_marginVertical="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
